// src/commands/artifact.ts
var artifactAddCommand = (opts) => Effect_exports.gen(function* () {
  if (!opts.task) {
    yield* Effect_exports.fail(new PithosError({ code: "VALIDATION_ERROR", message: "--task is required" }));
  }
  if (!opts.run) {
    yield* Effect_exports.fail(new PithosError({ code: "VALIDATION_ERROR", message: "--run is required" }));
  }
  if (!opts.kind) {
    yield* Effect_exports.fail(new PithosError({ code: "VALIDATION_ERROR", message: "--kind is required" }));
  }
  if (!opts.title) {
    yield* Effect_exports.fail(new PithosError({ code: "VALIDATION_ERROR", message: "--title is required" }));
  }
  const taskId = opts.task;
  const runId = opts.run;
  const kind = opts.kind;
  const title = opts.title;
  const db = yield* DbService;
  const ids3 = yield* IdService;
  const fs = yield* FsService;
  const output = yield* OutputService;
  yield* loadRequiredTaskRow(db, taskId);
  yield* loadRequiredRunRow(db, runId);
  const body = opts.bodyFile === void 0 ? "" : yield* fs.readFile(opts.bodyFile);
  const artifactId = yield* ids3.generate("artifact");
  const rows = yield* db.query(
    `INSERT INTO artifacts (id, task_id, run_id, kind, title, body)
       VALUES (?, ?, ?, ?, ?, ?)
       RETURNING *`,
    [artifactId, taskId, runId, kind, title, body]
  );
  if (rows.length !== 1) {
    yield* Effect_exports.fail(
      new PithosError({
        code: "INTERNAL_ERROR",
        message: `artifact insert returned ${rows.length} rows for ${artifactId}`
      })
    );
  }
  const artifact = yield* decodeArtifactRow(rows[0]);
  yield* output.print(JSON.stringify({ ok: true, artifact }));
}).pipe(
  Effect_exports.withLogSpan("pithos.task.artifact.add"),
  withCommandObservability("task.artifact.add")
);

