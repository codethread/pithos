  new_task_id: Schema_exports.String,
  scope_id: Schema_exports.String,
  status: Schema_exports.String,
  title: Schema_exports.String
}) {
};
var decodeSupersededDependencyRow = (row) => Schema_exports.decodeUnknown(SupersededDependencyRow)(row).pipe(
  Effect_exports.mapError(
    () => new PithosError({
