{
  "launchers": {
    "local_claude_tmux": {
      "kind": "tmux",
      "harness": "claude-code",
      "commands": {
        "spawn": "pandora-spawn --agent {{agent}} --scope {{scope_id}} --cwd {{cwd}}",
        "status": "pandora-spawn status --session-id {{session_id}} --lines {{lines}}",
        "nudge": "pandora-spawn nudge --target {{target}} --message {{message}}",
        "kill": "pandora-spawn kill --target {{target}}",
        "tty_status": "pandora-spawn tty-status --target {{target}}"
      },
      "meta": {
        "status_source": "claude_jsonl",
        "tty_provider": "tmux",
        "target_format": "pithos-<agent>-<session_id_first_8_chars>",
        "debug_rule": "Use status first. Use tty_status only if status is missing, stale, or debugging harness/TTY issues. The --target for nudge/kill/tty_status is the tmux_session field returned by spawn, derivable from session_id via target_format."
      }
    }
  },
  "agents": [
    {
      "agent": "pandora",
      "model": "sonnet",
      "cwd": "~/.pandora",
      "tools": [
        "Bash"
      ],
      "capability": "orchestrate",
      "type": "hitl",
      "includes": [
        "_common.md"
      ],
      "system_prompt": "pandora.md.tmpl",
      "launcher": "local_claude_tmux",
      "inject_meta": true
    },
    {
      "agent": "envy",
      "model": "sonnet",
      "tools": [
        "Bash",
        "Read",
        "Grep",
        "Glob"
      ],
      "capability": "implement",
      "type": "afk",
      "includes": [
        "_common.md"
      ],
      "system_prompt": "envy.md.tmpl",
      "launcher": "local_claude_tmux",
      "inject_meta": false
    },
    {
      "agent": "toil",
      "model": "sonnet",
      "tools": [
        "Bash",
        "Read",
        "Grep",
        "Glob"
      ],
      "capability": "triage",
      "type": "afk",
      "includes": [
        "_common.md"
      ],
      "system_prompt": "toil.md.tmpl",
      "launcher": "local_claude_tmux",
      "inject_meta": false
    }
  ]
}
