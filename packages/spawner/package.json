{
	"name": "@pdx/spawner",
	"version": "0.1.0",
	"private": true,
	"keywords": [
		"pi-package"
	],
	"bin": {
		"pandora-spawn": "./bin/pandora-spawn"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"clean": "rimraf dist bin/pandora-spawn bin/pandora-spawn-dev *.tsbuildinfo",
		"lint": "eslint .",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run --config vitest.config.ts",
		"build": "node scripts/build.mjs",
		"start": "node scripts/build.mjs --dev --run --"
	},
	"dependencies": {
		"@effect/cli": "catalog:",
		"@effect/platform": "catalog:",
		"@effect/platform-node": "catalog:",
		"@pdx/pithos": "workspace:*",
		"effect": "catalog:"
	}
}
