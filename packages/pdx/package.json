{
	"name": "@pithos/pdx",
	"version": "0.1.0",
	"private": true,
	"bin": {
		"pdx": "./bin/pdx"
	},
	"type": "module",
	"scripts": {
		"clean": "rimraf dist bin/pdx bin/pdx-dev *.tsbuildinfo",
		"lint": "eslint .",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run --config vitest.config.ts",
		"build": "node scripts/build.mjs",
		"start": "node scripts/build.mjs --dev --run --"
	},
	"dependencies": {
		"@effect/cli": "catalog:",
		"@effect/platform-node": "catalog:",
		"@pithos/pithos": "workspace:*",
		"@pithos/spawner": "workspace:*",
		"better-sqlite3": "^12.9.0",
		"effect": "catalog:"
	}
}
