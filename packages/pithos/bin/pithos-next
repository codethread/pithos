// src/layers/cli-console.ts
import { inspect } from "node:util";
var formatArgs = (args2) => args2.map((arg) => typeof arg === "string" ? arg : inspect(arg, { colors: true, depth: null })).join(" ");
var makeCliConsoleCapture = () => {
  const entries3 = [];
  const capture2 = (stream4, args2) => Effect_exports.sync(() => {
    entries3.push({ stream: stream4, text: formatArgs(args2) });
  });
  const unsafeWrite = (stream4, args2) => {
    const handle = stream4 === "stdout" ? process.stdout : process.stderr;
    handle.write(formatArgs(args2) + "\n");
  };
  const unsafeConsole = {
    assert: (condition, ...args2) => {
      if (!condition) {
        unsafeWrite("stderr", args2);
      }
    },
    clear: () => void 0,
    count: () => void 0,
    countReset: () => void 0,
    debug: (...args2) => unsafeWrite("stderr", args2),
    dir: (item) => unsafeWrite("stdout", [inspect(item, { colors: true, depth: null })]),
    dirxml: (...args2) => unsafeWrite("stdout", args2),
    error: (...args2) => unsafeWrite("stderr", args2),
    group: (...args2) => unsafeWrite("stdout", args2),
    groupCollapsed: (...args2) => unsafeWrite("stdout", args2),
    groupEnd: () => void 0,
    info: (...args2) => unsafeWrite("stdout", args2),
    log: (...args2) => unsafeWrite("stdout", args2),
    table: () => unsafeWrite("stdout", ["[console.table omitted]"]),
    time: () => void 0,
    timeEnd: () => void 0,
    timeLog: (_label, ...args2) => unsafeWrite("stdout", args2),
    trace: (...args2) => unsafeWrite("stderr", args2),
    warn: (...args2) => unsafeWrite("stderr", args2)
  };
  const consoleService = {
    [TypeId15]: TypeId15,
    assert: (condition, ...args2) => condition ? Effect_exports.void : capture2("stderr", args2),
    clear: Effect_exports.void,
    count: () => Effect_exports.void,
    countReset: () => Effect_exports.void,
    debug: (...args2) => capture2("stderr", args2),
    dir: (item) => capture2("stdout", [inspect(item, { colors: true, depth: null })]),
    dirxml: (...args2) => capture2("stdout", args2),
    error: (...args2) => capture2("stderr", args2),
    group: (options3) => options3?.label === void 0 ? Effect_exports.void : capture2("stdout", [options3.label]),
    groupEnd: Effect_exports.void,
    info: (...args2) => capture2("stdout", args2),
    log: (...args2) => capture2("stdout", args2),
    table: () => capture2("stdout", ["[console.table omitted]"]),
    time: () => Effect_exports.void,
    timeEnd: () => Effect_exports.void,
    timeLog: (_label, ...args2) => capture2("stdout", args2),
    trace: (...args2) => capture2("stderr", args2),
    warn: (...args2) => capture2("stderr", args2),
    unsafe: unsafeConsole
  };
