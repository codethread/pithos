#!/usr/bin/env bash
# Called by the pandora SessionStart hook.
# Starts pandora/bin/watch-inbox in a dedicated tmux session if not already running.

if [[ ${1:-} == --help ]]; then
  cat <<'EOF'
Usage: pandora/bin/watch-inbox-start

Idempotently starts the pandora--watch-inbox tmux session.
EOF
  exit 0
fi

VAULT="$(cd "$(dirname "$0")/../.." && pwd)"

if ! tmux has-session -t pandora--watch-inbox 2>/dev/null; then
  tmux new-session -d -s pandora--watch-inbox -c "$VAULT" "$VAULT/pandora/bin/watch-inbox"
  echo "pandora--watch-inbox started"
else
  echo "pandora--watch-inbox already running"
fi
