    function onTick() {
      fastNow += TICK_MS;
      let idx = 0;
      let len = fastTimers.length;
      while (idx < len) {
        const timer3 = fastTimers[idx];
        if (timer3._state === PENDING) {
          timer3._idleStart = fastNow - TICK_MS;
          timer3._state = ACTIVE;
        } else if (timer3._state === ACTIVE && fastNow >= timer3._idleStart + timer3._idleTimeout) {
          timer3._state = TO_BE_CLEARED;
          timer3._idleStart = -1;
          timer3._onTimeout(timer3._timerArg);
        }
