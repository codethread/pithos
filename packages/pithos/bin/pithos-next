// src/layers/logger.ts
var getEnvLogLevel = () => {
  const raw = process.env.PITHOS_LOG_LEVEL?.toLowerCase();
  switch (raw) {
    case "trace":
      return LogLevel_exports.Trace;
    case "debug":
      return LogLevel_exports.Debug;
    case "info":
      return LogLevel_exports.Info;
    case "warning":
    case "warn":
      return LogLevel_exports.Warning;
    case "error":
      return LogLevel_exports.Error;
    case "fatal":
      return LogLevel_exports.Fatal;
    case "none":
      return LogLevel_exports.None;
    default:
      return LogLevel_exports.None;
  }
};
var pithosStderrLogger = Logger_exports.make(
  ({ logLevel: logLevel2, message, date: date9, spans: spans2, annotations: annotations3 }) => {
    const entry = {
      ts: date9.toISOString(),
      level: logLevel2.label,
      msg: String(message)
    };
    if (List_exports.isCons(spans2)) {
      const labels = [];
      for (const s of spans2) labels.push(s.label);
      entry.spans = labels;
    }
    if (HashMap_exports.size(annotations3) > 0) {
      const ctx = {};
      for (const [k, v] of annotations3) ctx[k] = String(v);
      entry.ctx = ctx;
    }
    process.stderr.write(JSON.stringify(entry) + "\n");
  }
);
