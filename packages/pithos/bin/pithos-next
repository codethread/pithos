    "use strict";
    var Document = require_Document();
    var composeNode = require_compose_node();
    var resolveEnd = require_resolve_end();
    var resolveProps = require_resolve_props();
    function composeDoc(options3, directives, { offset, start: start4, value: value8, end: end5 }, onError4) {
      const opts = Object.assign({ _directives: directives }, options3);
      const doc = new Document.Document(void 0, opts);
      const ctx = {
        atKey: false,
        atRoot: true,
        directives: doc.directives,
        options: doc.options,
        schema: doc.schema
      };
      const props = resolveProps.resolveProps(start4, {
        indicator: "doc-start",
        next: value8 ?? end5?.[0],
        offset,
        onError: onError4,
        parentIndent: 0,
        startOnNewline: true
      });
      if (props.found) {
        doc.directives.docStart = true;
        if (value8 && (value8.type === "block-map" || value8.type === "block-seq") && !props.hasNewline)
          onError4(props.end, "MISSING_CHAR", "Block collection cannot start on same line with directives-end marker");
      }
      doc.contents = value8 ? composeNode.composeNode(ctx, value8, props, onError4) : composeNode.composeEmptyNode(ctx, props.end, start4, null, props, onError4);
      const contentEnd = doc.contents.range[2];
      const re = resolveEnd.resolveEnd(end5, contentEnd, false, onError4);
