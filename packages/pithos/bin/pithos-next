var assertCapabilityScopeAllowed = (capability, scope6) => Effect_exports.gen(function* () {
  switch (capability) {
    case "triage":
    case "design":
      return;
    case "escalate": {
      if (scope6.kind !== "global") {
        yield* Effect_exports.fail(
          new PithosError({
            code: "VALIDATION_ERROR",
            message: `escalate requires global scope; got ${scope6.id} kind=${scope6.kind}`
          })
        );
      }
      return;
    }
    case "execute": {
      if (scope6.kind !== "repo" && scope6.kind !== "worktree" || scope6.canonical_path === null) {
        yield* Effect_exports.fail(
          new PithosError({
            code: "VALIDATION_ERROR",
            message: `execute requires scope kind in {repo, worktree} with non-null canonical_path; got ${scope6.id} kind=${scope6.kind}`
          })
        );
      }
      return;
    }
  }
});
var assertRunCapability = (run10, capability, table2, verb) => Effect_exports.gen(function* () {
  const db = yield* DbService;
  const rows = yield* db.query(
    `SELECT agent_kind
       FROM ${table2}
       WHERE agent_kind = ?
         AND capability = ?`,
    [run10.agent_kind, capability]
  );
  if (rows.length === 0) {
    yield* Effect_exports.fail(
      new PithosError({
        code: "USER_ERROR",
        message: `Agent kind ${run10.agent_kind} cannot ${verb} capability ${capability}`
      })
    );
  }
});
