var sqlString = (value8) => `'${value8.replaceAll("'", "''")}'`;
var sqlTuples = (rows) => rows.map((row) => `(${row.map(sqlString).join(", ")})`).join(", ");
var claimSeedRows = Object.entries(AGENT_CLAIMS_BY_KIND).flatMap(
  ([agentKind, capabilities]) => capabilities.map((capability) => [agentKind, capability])
