// src/commands/claim.ts
var TERMINAL_RUN_STATUSES = /* @__PURE__ */ new Set(["ended", "failed", "cancelled", "timed_out"]);
var claimCommand = (opts) => Effect_exports.gen(function* () {
  if (opts.run === void 0) {
    yield* Effect_exports.fail(new PithosError({ code: "VALIDATION_ERROR", message: "--run is required" }));
  }
  if (opts.scope === void 0) {
    yield* Effect_exports.fail(new PithosError({ code: "VALIDATION_ERROR", message: "--scope is required" }));
  }
  if (opts.capability === void 0) {
    yield* Effect_exports.fail(
      new PithosError({ code: "VALIDATION_ERROR", message: "--capability is required" })
    );
  }
  const runId = opts.run;
  const scopeId = opts.scope;
  const capability = yield* decodeCapability(opts.capability);
  const db = yield* DbService;
  const output = yield* OutputService;
  const claimedTask = yield* db.withTransaction(
    Effect_exports.gen(function* () {
      const run10 = yield* loadRequiredRunRow(db, runId);
      const scope6 = yield* loadRequiredScopeRow(db, scopeId);
      if (TERMINAL_RUN_STATUSES.has(run10.status)) {
        yield* Effect_exports.fail(
          new PithosError({
            code: "USER_ERROR",
            message: `Run ${runId} is terminal (${run10.status}) and cannot claim work`
          })
        );
      }
      if (run10.scope_id !== scopeId) {
        yield* Effect_exports.fail(
          new PithosError({
            code: "VALIDATION_ERROR",
            message: `Claim scope mismatch: run ${runId} is registered in scope ${run10.scope_id}, not ${scopeId}`
          })
        );
      }
      if (run10.task_id !== null) {
        yield* Effect_exports.fail(
          new PithosError({
            code: "VALIDATION_ERROR",
            message: `Run ${runId} already holds task ${run10.task_id}`
          })
        );
      }
      yield* assertCapabilityScopeAllowed(capability, scope6);
      yield* Effect_exports.provideService(assertRunCanClaimCapability(run10, capability), DbService, db);
      const taskRows = yield* db.query(
        `UPDATE tasks
           SET
             status = 'claimed',
             fencing_token = fencing_token + 1,
             attempts = attempts + 1,
             updated_at = CURRENT_TIMESTAMP
           WHERE id = (
             SELECT t.id
             FROM tasks t
             WHERE t.status = 'queued'
               AND t.scope_id = ?
               AND t.capability = ?
               AND NOT EXISTS (
                 SELECT 1
                 FROM task_dependencies td
                 JOIN tasks dep ON dep.id = td.depends_on_task_id
                 WHERE td.task_id = t.id
                   AND dep.status <> 'done'
               )
             ORDER BY t.created_at ASC, t.id ASC
             LIMIT 1
           )
             AND status = 'queued'
           RETURNING *`,
        [scopeId, capability]
      );
      if (taskRows.length === 0) {
        return null;
      }
      const task2 = yield* decodeTaskRow(taskRows[0]);
      const runRows = yield* db.query(
        `UPDATE runs
           SET task_id = ?, updated_at = CURRENT_TIMESTAMP
           WHERE id = ?
             AND task_id IS NULL
             AND scope_id = ?
           RETURNING id`,
        [task2.id, runId, scopeId]
      );
      if (runRows.length === 0) {
        yield* Effect_exports.fail(
          new PithosError({
            code: "VALIDATION_ERROR",
            message: `Run ${runId} can no longer claim work; task ownership changed concurrently`
          })
        );
      }
      yield* decodeIdRow(runRows[0]);
      yield* db.run(
        `INSERT INTO events (task_id, actor_run_id, type, payload_json)
           VALUES (?, ?, 'task.claimed', ?)`,
        [
          task2.id,
          runId,
          JSON.stringify({ run_id: runId, fencing_token: task2.fencing_token })
        ]
      );
      return task2;
    })
  );
  if (claimedTask === null) {
    yield* Effect_exports.logDebug("no claimable work").pipe(
      Effect_exports.annotateLogs({ scopeId, capability })
    );
    yield* Effect_exports.fail(
      new PithosError({ code: "NO_CLAIMABLE_WORK", message: "no claimable work found" })
    );
    return yield* Effect_exports.never;
  }
  yield* Metric_exports.increment(tasksClaimedCounter);
  yield* Effect_exports.logDebug("task claimed").pipe(
    Effect_exports.annotateLogs({ taskId: claimedTask.id, runId })
  );
  yield* output.print(JSON.stringify({ ok: true, task: claimedTask }));
}).pipe(Effect_exports.withLogSpan("pithos.task.claim"), withCommandObservability("task.claim"));

// src/commands/complete.ts
var completeCommand = (opts) => Effect_exports.gen(function* () {
  if (!opts.taskId) {
    yield* Effect_exports.fail(
      new PithosError({ code: "VALIDATION_ERROR", message: "task id argument is required" })
    );
  }
  if (!opts.run) {
    yield* Effect_exports.fail(new PithosError({ code: "VALIDATION_ERROR", message: "--run is required" }));
  }
  if (opts.token === void 0) {
    yield* Effect_exports.fail(new PithosError({ code: "VALIDATION_ERROR", message: "--token is required" }));
  }
  yield* Schema_exports.decodeUnknown(Schema_exports.Int)(opts.token).pipe(
    Effect_exports.mapError(
      () => new PithosError({
        code: "VALIDATION_ERROR",
        message: `--token must be an integer, got: ${String(opts.token)}`
      })
    )
  );
  const taskId = opts.taskId;
  const runId = opts.run;
  const token = opts.token;
  const fs = yield* FsService;
  const output = yield* OutputService;
  let resultJson = "{}";
  if (opts.resultFile) {
    const raw = yield* fs.readFile(opts.resultFile);
    yield* Schema_exports.decodeUnknown(Schema_exports.parseJson(Schema_exports.Unknown))(raw).pipe(
      Effect_exports.mapError(
        () => new PithosError({
          code: "VALIDATION_ERROR",
          message: `--result-file does not contain valid JSON: ${opts.resultFile}`
        })
      )
    );
    resultJson = raw.trim();
  }
  const db = yield* DbService;
  const txResult = yield* db.withTransaction(
    Effect_exports.gen(function* () {
      const taskRows = yield* db.query(
        `UPDATE tasks
           SET
             status = 'done',
             result_json = ?,
             completed_at = CURRENT_TIMESTAMP,
             updated_at = CURRENT_TIMESTAMP
           WHERE id = ?
             AND fencing_token = ?
             AND status IN ('claimed', 'running')
             AND EXISTS (
               SELECT 1
               FROM runs
               WHERE id = ?
                 AND task_id = tasks.id
             )
           RETURNING *`,
        [resultJson, taskId, token, runId]
      );
      if (taskRows.length === 0) {
        return { kind: "stale_token" };
      }
      const task2 = yield* decodeTaskRow(taskRows[0]);
      yield* db.run(
        `INSERT INTO events (task_id, actor_run_id, run_id, type, payload_json)
           VALUES (?, ?, ?, 'task.completed', ?)`,
        [task2.id, runId, runId, JSON.stringify({ run_id: runId, fencing_token: token })]
      );
      const runRows = yield* db.query(
        `UPDATE runs
           SET task_id = NULL, updated_at = CURRENT_TIMESTAMP
           WHERE id = ?
             AND task_id = ?
           RETURNING id`,
        [runId, taskId]
      );
      if (runRows.length !== 1) {
        yield* Effect_exports.fail(
          new PithosError({
            code: "STALE_TOKEN",
            message: "concurrent run state change invalidated task completion"
          })
        );
      }
      yield* decodeIdRow(runRows[0]);
      return { kind: "success", task: task2 };
    })
  );
  if (txResult.kind === "stale_token") {
    yield* Metric_exports.increment(staleTokensCompleteCounter);
    yield* Effect_exports.logWarning("stale fencing token rejected on complete").pipe(
      Effect_exports.annotateLogs({ taskId, runId, token: String(token) })
    );
    yield* Effect_exports.fail(
      new PithosError({ code: "STALE_TOKEN", message: `Stale fencing token for task: ${taskId}` })
    );
  }
  yield* Effect_exports.logDebug("task completed").pipe(Effect_exports.annotateLogs({ taskId, runId }));
  yield* output.print(JSON.stringify({ ok: true, task: txResult.task }));
}).pipe(Effect_exports.withLogSpan("pithos.task.complete"), withCommandObservability("task.complete"));

