#!/usr/bin/env bash
# pithos CLI entry point
# Runs via tsx (development). Compile to dist/ for production packaging.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
TSX="$WORKSPACE_ROOT/node_modules/.bin/tsx"

exec "$TSX" "$SCRIPT_DIR/../src/main.ts" "$@"
