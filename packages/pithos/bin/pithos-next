        return kt;
      }
      onError4(tagToken, "TAG_RESOLVE_FAILED", `Unresolved tag: ${tagName}`, tagName !== "tag:yaml.org,2002:str");
      return schema[identity4.SCALAR];
    }
    function findScalarTagByTest({ atKey, directives, schema }, value8, token, onError4) {
      const tag5 = schema.tags.find((tag6) => (tag6.default === true || atKey && tag6.default === "key") && tag6.test?.test(value8)) || schema[identity4.SCALAR];
      if (schema.compat) {
        const compat = schema.compat.find((tag6) => tag6.default && tag6.test?.test(value8)) ?? schema[identity4.SCALAR];
        if (tag5.tag !== compat.tag) {
          const ts = directives.tagString(tag5.tag);
          const cs = directives.tagString(compat.tag);
          const msg = `Value may be parsed as either ${ts} or ${cs}`;
          onError4(token, "TAG_RESOLVE_FAILED", msg, true);
        }
      }
      return tag5;
    }
    exports.composeScalar = composeScalar;
