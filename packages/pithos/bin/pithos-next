        case "single-quoted-scalar":
          _type = Scalar.Scalar.QUOTE_SINGLE;
          value8 = singleQuotedValue(source, _onError);
          break;
        case "double-quoted-scalar":
          _type = Scalar.Scalar.QUOTE_DOUBLE;
          value8 = doubleQuotedValue(source, _onError);
          break;
