{
  "description": "Pithos liveness heartbeat and clean session-end hooks. No-ops in normal Claude sessions; only active when PITHOS_AGENT and PITHOS_RUN_ID are set by pandora-spawn.",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh PreToolUse"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "prompt_input_exit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/dispatch.sh SessionEnd"
          }
        ]
      }
    ]
  }
}
