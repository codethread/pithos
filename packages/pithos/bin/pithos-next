var filterTerminalChains = (graph2) => {
  if (graph2.nodes.length === 0) return graph2;
  const supersededByLookup = /* @__PURE__ */ new Map();
  for (const node of graph2.nodes) {
    if (node.supersedes_task_id !== null) {
      supersededByLookup.set(node.supersedes_task_id, node);
    }
  }
  const supersessionParticipantIds = /* @__PURE__ */ new Set();
  for (const node of graph2.nodes) {
    if (node.supersedes_task_id !== null || node.superseded_by_task_id !== null || supersededByLookup.has(node.id)) {
      supersessionParticipantIds.add(node.id);
    }
  }
  const terminalStatuses = /* @__PURE__ */ new Set(["done", "cancelled"]);
  const terminalNodeIds = /* @__PURE__ */ new Set();
  const chainRoots = graph2.nodes.filter(
    (node) => node.supersedes_task_id === null && (node.superseded_by_task_id !== null || supersededByLookup.has(node.id))
  );
  for (const root of chainRoots) {
    const chainNodes = [root];
    let current = supersededByLookup.get(root.id);
    while (current !== void 0) {
      chainNodes.push(current);
      current = supersededByLookup.get(current.id);
    }
    if (chainNodes.every((node) => terminalStatuses.has(node.status))) {
      for (const node of chainNodes) {
        terminalNodeIds.add(node.id);
      }
    }
  }
  for (const node of graph2.nodes) {
    if (!supersessionParticipantIds.has(node.id) && terminalStatuses.has(node.status)) {
      terminalNodeIds.add(node.id);
    }
  }
  if (terminalNodeIds.size === 0) return graph2;
  return {
    nodes: graph2.nodes.filter((node) => !terminalNodeIds.has(node.id)),
    edges: graph2.edges.filter(
      (edge) => !terminalNodeIds.has(edge.from_task_id) && !terminalNodeIds.has(edge.to_task_id)
    )
  };
};
var renderGraphFlat = (graph2) => {
  if (graph2.nodes.length === 0) return "";
  const supersededByLookup = /* @__PURE__ */ new Map();
  for (const node of graph2.nodes) {
    if (node.supersedes_task_id !== null) {
      supersededByLookup.set(node.supersedes_task_id, node);
    }
  }
  const supersessionRoots = graph2.nodes.filter(
    (node) => node.supersedes_task_id === null && (node.superseded_by_task_id !== null || supersededByLookup.has(node.id))
  );
  const standaloneNodes = graph2.nodes.filter(
    (node) => node.supersedes_task_id === null && node.superseded_by_task_id === null && !supersededByLookup.has(node.id)
  );
  if (supersessionRoots.length === 0 && standaloneNodes.length === 0) {
    return "";
  }
  const renderChain = (root) => {
    const lines3 = [];
    let current = root;
    let depth = 0;
    while (current !== void 0) {
      lines3.push(`${"  ".repeat(depth)}[${current.status}] ${current.title}`);
      current = supersededByLookup.get(current.id);
      depth += 1;
    }
    return lines3.join("\n");
  };
  const chainBlocks = supersessionRoots.map(renderChain);
  const standaloneBlocks = standaloneNodes.map((node) => `[${node.status}] ${node.title}`);
  return [...chainBlocks, ...standaloneBlocks].join("\n\n");
};
var inspectGraphCommand = (selector, flat, dump2) => Effect_exports.gen(function* () {
  const output = yield* OutputService;
  const graph2 = selector.kind === "task" ? yield* loadTaskGraph(selector.value) : selector.kind === "scope" ? yield* loadScopeTaskGraph(selector.value) : yield* loadCurrentTaskGraph();
  if (flat) {
    const displayGraph = dump2 ? graph2 : filterTerminalChains(graph2);
    yield* output.print(renderGraphFlat(displayGraph));
    return;
  }
  yield* output.print(
    JSON.stringify({
      ok: true,
      graph: {
        selector,
        nodes: graph2.nodes,
        edges: graph2.edges
      }
    })
  );
}).pipe(Effect_exports.withLogSpan("pithos.graph.inspect"), withCommandObservability("graph.inspect"));
