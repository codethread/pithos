  const db = yield* DbService;
  const output = yield* OutputService;
  const { maxEventId, allTasks, queuedTaskStates, staleRuns, artifacts, heldTaskRows } = yield* db.withTransaction(
    Effect_exports.gen(function* () {
      const tasks = yield* db.query(BRIEFING_SQL.TASKS).pipe(
        Effect_exports.flatMap((rows) => Effect_exports.forEach(rows, decodeTaskRow))
      );
      const queuedTaskStates2 = yield* Effect_exports.forEach(
        tasks.filter((task2) => task2.status === "queued"),
        (task2) => Effect_exports.provideService(loadUnresolvedDependencies(task2.id), DbService, db).pipe(
          Effect_exports.map(
            (unresolvedBlockers) => ({
              task: task2,
              unresolvedBlockers
            })
          )
        )
      );
      const staleRuns2 = yield* db.query(BRIEFING_SQL.STALE_RUNS).pipe(
        Effect_exports.flatMap((rows) => Effect_exports.forEach(rows, decodeRunRow))
      );
      const artifacts2 = yield* db.query(BRIEFING_SQL.ARTIFACTS).pipe(
        Effect_exports.flatMap((rows) => Effect_exports.forEach(rows, decodeArtifactRow))
      );
      const heldTaskRows2 = yield* db.query(BRIEFING_SQL.HELD_TASKS).pipe(
        Effect_exports.flatMap((rows) => Effect_exports.forEach(rows, decodeHeldTaskRow))
      );
      const watermarkRows = yield* db.query(BRIEFING_SQL.WATERMARK);
      const watermark = watermarkRows[0] === void 0 ? null : yield* decodeMaxIdRow(watermarkRows[0]);
      return {
        maxEventId: watermark?.max_id ?? 0,
        allTasks: tasks,
        queuedTaskStates: queuedTaskStates2,
        staleRuns: staleRuns2,
        artifacts: artifacts2,
        heldTaskRows: heldTaskRows2
      };
    })
  );
  const artifactsByTaskId = /* @__PURE__ */ new Map();
  for (const artifact of artifacts) {
    const existing = artifactsByTaskId.get(artifact.task_id) ?? [];
    existing.push(artifact);
    artifactsByTaskId.set(artifact.task_id, existing);
  }
  const holderByTaskId = /* @__PURE__ */ new Map();
  for (const heldTask of heldTaskRows) {
    holderByTaskId.set(heldTask.task_id, heldTask.run_id);
  }
  const claimedOrRunningTasks = allTasks.filter(
    (task2) => task2.status === "claimed" || task2.status === "running"
  );
  const doneTasks = allTasks.filter((task2) => task2.status === "done");
  const failedTasks = allTasks.filter((task2) => task2.status === "failed");
  const deadLetterTasks = allTasks.filter((task2) => task2.status === "dead_letter");
  const readyQueuedTasks = queuedTaskStates.filter((state) => state.unresolvedBlockers.length === 0);
  const blockedQueuedTasks = queuedTaskStates.filter((state) => state.unresolvedBlockers.length > 0);
  const questionArtifacts = artifacts.filter((artifact) => artifact.kind === "question");
  const lines3 = [];
  lines3.push("## Pandora briefing");
  lines3.push("");
  lines3.push(`as_of_event_id: ${maxEventId}`);
  lines3.push("");
  lines3.push("### Needs Adam");
  lines3.push("");
  const needsAdamItems = [];
  for (const task2 of deadLetterTasks) {
    needsAdamItems.push(
      `- [dead_letter] \`${task2.id}\`: "${task2.title}" (scope: ${task2.scope_id}, capability: ${task2.capability}, attempts: ${task2.attempts}/${task2.max_attempts})`
    );
  }
  for (const artifact of questionArtifacts) {
    needsAdamItems.push(
      `- [question] \`${artifact.task_id}\`: "${artifact.title}" (${artifact.created_at})`
    );
  }
  lines3.push(...needsAdamItems.length === 0 ? ["_nothing_"] : needsAdamItems);
  lines3.push("");
  lines3.push("### Ready for review");
  lines3.push("");
  const reviewItems = [];
  for (const task2 of doneTasks) {
    const taskArtifacts = artifactsByTaskId.get(task2.id) ?? [];
    const reviewArtifacts = taskArtifacts.filter(
      (artifact) => artifact.kind === "war-completion" || artifact.kind === "design-brief"
    );
    const taskLine = `- [done] \`${task2.id}\`: "${task2.title}" (scope: ${task2.scope_id}, capability: ${task2.capability})`;
    if (reviewArtifacts.length === 0) {
      reviewItems.push(taskLine);
      continue;
    }
    reviewItems.push(
      `${taskLine}
${reviewArtifacts.map((artifact) => `  - ${artifact.kind}: "${artifact.title}" (${artifact.created_at})`).join("\n")}`
    );
  }
  lines3.push(...reviewItems.length === 0 ? ["_nothing_"] : reviewItems);
  lines3.push("");
  lines3.push("### Active");
  lines3.push("");
  lines3.push("#### Ready queued");
  lines3.push(
    ...readyQueuedTasks.length === 0 ? ["_nothing_"] : readyQueuedTasks.map(({ task: task2 }) => renderActiveTaskLine(task2, holderByTaskId.get(task2.id)))
  );
  lines3.push("");
  lines3.push("#### Blocked queued");
  if (blockedQueuedTasks.length === 0) {
    lines3.push("_nothing_");
  } else {
    for (const blockedTask of blockedQueuedTasks) {
      lines3.push(renderActiveTaskLine(blockedTask.task, holderByTaskId.get(blockedTask.task.id), "queued blocked"));
      lines3.push(...blockedTask.unresolvedBlockers.map(renderBlockerLine));
    }
  }
  lines3.push("");
  lines3.push("#### Claimed / running");
  lines3.push(
    ...claimedOrRunningTasks.length === 0 ? ["_nothing_"] : claimedOrRunningTasks.map((task2) => renderActiveTaskLine(task2, holderByTaskId.get(task2.id)))
  );
  lines3.push("");
  lines3.push("### Stale / failed");
  lines3.push("");
  const staleItems = [];
  for (const run10 of staleRuns) {
    const heartbeat = run10.last_heartbeat_at ?? run10.created_at;
    staleItems.push(
      `- [${run10.status}] \`${run10.id}\`: ${run10.agent_kind} (${run10.mode}, last heartbeat: ${heartbeat})`
    );
  }
  for (const task2 of failedTasks) {
    staleItems.push(
      `- [failed] \`${task2.id}\`: "${task2.title}" (scope: ${task2.scope_id}, capability: ${task2.capability}, attempts: ${task2.attempts}/${task2.max_attempts})`
    );
  }
  lines3.push(...staleItems.length === 0 ? ["_nothing_"] : staleItems);
  lines3.push("");
  yield* output.print(lines3.join("\n"));
}).pipe(Effect_exports.withLogSpan("pithos.briefing"), withCommandObservability("briefing"));

// src/commands/cancel.ts
var cancelCommand = (opts) => Effect_exports.gen(function* () {
  if (!opts.taskId) {
    yield* Effect_exports.fail(
      new PithosError({ code: "VALIDATION_ERROR", message: "task id argument is required" })
    );
  }
  if (!opts.run) {
    yield* Effect_exports.fail(new PithosError({ code: "VALIDATION_ERROR", message: "--run is required" }));
  }
  if (opts.reason === void 0 || opts.reason.trim().length === 0) {
    yield* Effect_exports.fail(
      new PithosError({ code: "VALIDATION_ERROR", message: "--reason is required" })
    );
  }
  const taskId = opts.taskId;
  const runId = opts.run;
  const reason = opts.reason.trim();
  const db = yield* DbService;
  const output = yield* OutputService;
  const task2 = yield* db.withTransaction(
    Effect_exports.gen(function* () {
      yield* loadRequiredRunRow(db, runId);
      const task3 = yield* loadRequiredTaskRow(db, taskId);
      switch (task3.status) {
        case "queued":
        case "failed":
        case "dead_letter":
          break;
        case "claimed":
        case "running":
          yield* Effect_exports.fail(
            new PithosError({
              code: "USER_ERROR",
              message: `Cannot cancel task ${taskId} while it is ${task3.status}; use pdx kill / pithos run interrupt`
            })
          );
          break;
        case "done":
          yield* Effect_exports.fail(
            new PithosError({
              code: "USER_ERROR",
              message: `Cannot cancel task ${taskId} because it is done`
            })
          );
          break;
        case "cancelled":
          yield* Effect_exports.fail(
            new PithosError({
              code: "USER_ERROR",
              message: `Task ${taskId} is already cancelled`
            })
          );
          break;
      }
      const updatedRows = yield* db.query(
        `UPDATE tasks
           SET status = 'cancelled', updated_at = CURRENT_TIMESTAMP
           WHERE id = ?
             AND status = ?
           RETURNING *`,
        [taskId, task3.status]
      );
      if (updatedRows.length !== 1) {
        yield* Effect_exports.fail(
          new PithosError({
            code: "USER_ERROR",
            message: `Task ${taskId} changed state before cancellation completed`
          })
        );
      }
      const cancelledTask = yield* decodeTaskRow(updatedRows[0]);
      yield* db.run(
        `INSERT INTO events (task_id, actor_run_id, type, payload_json)
           VALUES (?, ?, 'task.cancelled', ?)`,
        [taskId, runId, JSON.stringify({ reason })]
      );
      return cancelledTask;
    })
  );
  yield* output.print(JSON.stringify({ ok: true, task: task2 }));
}).pipe(Effect_exports.withLogSpan("pithos.task.cancel"), withCommandObservability("task.cancel"));

