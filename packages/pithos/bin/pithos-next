  "../../node_modules/.pnpm/yaml@2.8.3/node_modules/yaml/dist/compose/resolve-end.js"(exports) {
    "use strict";
    function resolveEnd(end5, offset, reqSpace, onError4) {
      let comment = "";
      if (end5) {
        let hasSpace = false;
        let sep = "";
        for (const token of end5) {
          const { source, type: type2 } = token;
          switch (type2) {
            case "space":
              hasSpace = true;
              break;
            case "comment": {
              if (reqSpace && !hasSpace)
                onError4(token, "MISSING_CHAR", "Comments must be separated from other tokens by white space characters");
