    `SELECT id
       FROM tasks
       WHERE scope_id = ?
         AND status <> 'cancelled'
       ORDER BY created_at ASC, id ASC`,
    [scopeId]
  );
  return yield* loadTaskGraphFromSeedTaskIds(seedTaskIds);
});
var loadCurrentTaskGraph = () => loadIdRows(
  `SELECT id
     FROM tasks
     WHERE status <> 'cancelled'
     ORDER BY created_at ASC, id ASC`
).pipe(
  Effect_exports.flatMap(loadCurrentTaskGraphConnectedTaskIds),
