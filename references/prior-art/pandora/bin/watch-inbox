#!/usr/bin/env bash
set -euo pipefail

# pandora/bin/watch-inbox — inbox nudge loop for canonical Pandora.
#
# Flow:
# 1. Every 5 minutes, read pandora/tasks/inbox.md.
# 2. Ignore the default `# Inbox` heading; continue only if real content remains.
# 3. Find the active canonical `pandora--pandora` tmux pane via tmux-agent-switch.
# 4. Resolve Pandora's latest Claude session UUID from the cwd-scoped
#    ~/.claude/projects/<cwd-slug>/*.jsonl file set.
# 5. Read recent activity with pandora/bin/status <uuid> --lines 5.
# 6. Ask Pi whether Pandora looks busy or idle, using tmux preview + status tail.
# 7. If Pi returns `NUDGE`, send:
#    <system-reminder>you have mail!</system-reminder>
#
# Runs in a dedicated tmux session and polls forever.

if [[ ${1:-} == --help ]]; then
  cat <<'EOF'
Usage: pandora/bin/watch-inbox

Every 5 minutes:
- read pandora/tasks/inbox.md
- ignore the default `# Inbox` heading
- if real content remains, find active canonical `pandora--pandora`
- resolve Pandora's latest Claude session UUID for this cwd
- read pandora/bin/status <uuid> --lines 5
- ask Pi whether Pandora looks idle
- if yes, send a tmux nudge with `<system-reminder>you have mail!</system-reminder>`
EOF
  exit 0
fi

VAULT="$(cd "$(dirname "$0")/../.." && pwd)"
INBOX="$VAULT/pandora/tasks/inbox.md"
STATUS_BIN="$VAULT/pandora/bin/status"

log() { printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*"; }

inbox_has_work() {
  [[ -f "$INBOX" ]] || return 1
  awk '
    tolower($0) ~ /^[[:space:]]*# inbox[[:space:]]*$/ { next }
    /[^[:space:]]/ { found = 1 }
    END { exit(found ? 0 : 1) }
  ' "$INBOX"
}

get_pandora_session_json() {
  tmux-agent-switch --json | jq -c '
    map(select(.session == "pandora--pandora" and .session_type == "canonical" and .active == true))
    | first
    | select(.pane_id != null)
  '
}

claude_project_slug() {
  printf '%s' "$VAULT" | LC_ALL=C tr -c '[:alnum:]' '-'
}

latest_pandora_session_id() {
  local project_dir latest
  project_dir="$HOME/.claude/projects/$(claude_project_slug)"
  [[ -d "$project_dir" ]] || return 1
  latest="$(ls -1t "$project_dir"/*.jsonl 2>/dev/null | head -n 1)"
  [[ -n "$latest" ]] || return 1
  latest="${latest##*/}"
  printf '%s\n' "${latest%.jsonl}"
}

get_recent_status() {
  local session_id="$1"
  "$STATUS_BIN" "$session_id" --lines 5 2>/dev/null
}

decide_nudge() {
  local preview="$1"
  local status="$2"
  local prompt
  prompt=$(cat <<EOF
your job is to see if pandora needs a nudge.
current time: $(date '+%Y-%m-%d %H:%M:%S')

recent tmux preview:
$preview

recent pandora/bin/status output:
$status

If she looks actively busy, output only: NOPE
If she looks idle, waiting, or done and should check inbox, output only: NUDGE
EOF
)
  echo "$prompt" | pi --model openai/gpt-5.4-nano:off --no-session --no-skills --no-extensions --print 2>/dev/null | tr -d '\r' | tail -n 1
}

while true; do
  if ! inbox_has_work; then
    sleep 300
    continue
  fi

  session_json="$(get_pandora_session_json || true)"
  pane_id="$(jq -r '.pane_id // empty' <<<"$session_json")"
  preview="$(jq -r '.preview // empty' <<<"$session_json")"
  if [[ -z "${pane_id:-}" ]]; then
    log "no canonical pandora session found"
    sleep 300
    continue
  fi

  session_id="$(latest_pandora_session_id || true)"
  if [[ -z "${session_id:-}" ]]; then
    log "could not resolve pandora session uuid"
    sleep 300
    continue
  fi

  status="$(get_recent_status "$session_id" || true)"
  decision="$(decide_nudge "$preview" "$status" || true)"
  if [[ "$decision" == "NUDGE" ]]; then
    tmux send-keys -t "$pane_id" "<system-reminder>you have mail!</system-reminder>" Enter
    log "nudged pandora via $pane_id (session $session_id)"
  else
    log "pandora looks busy or no nudge needed (session $session_id)"
  fi

  sleep 300
done
